{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ksml.io/sensordata-v2.json",
  "title": "SensorData",
  "description": "Sensor data schema v2 (10 properties — adds optional location and accuracy)",
  "type": "object",
  "properties": {
    "name":      { "description": "Sensor name",             "type": "string" },
    "timestamp": { "description": "Reading timestamp",       "type": "number" },
    "value":     { "description": "Sensor value (string)",   "type": "string" },
    "type":      { "description": "Sensor type",             "type": "string", "enum": ["AREA","HUMIDITY","LENGTH","STATE","TEMPERATURE"] },
    "unit":      { "description": "Unit of measurement",     "type": "string" },
    "color":     { "description": "Sensor color",            "type": "string" },
    "city":      { "description": "Sensor city",             "type": "string" },
    "owner":     { "description": "Sensor owner",            "type": "string" },
    "location":  { "description": "Sensor location",         "type": "string" },
    "accuracy":  { "description": "Reading accuracy",        "type": "number" }
  },
  "required": ["name", "timestamp", "value", "type", "unit"]
}
