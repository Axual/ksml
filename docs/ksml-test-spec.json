{
  "$schema" : "http://json-schema.org/draft-07/schema#",
  "title" : "KSML Test Definition",
  "description" : "Schema for KSML test runner YAML definition files",
  "type" : "object",
  "properties" : {
    "test" : {
      "type" : "object",
      "description" : "KSML test definition",
      "properties" : {
        "name" : {
          "type" : "string",
          "description" : "Human-readable test name",
          "examples" : [ "Filter keeps only blue sensors" ]
        },
        "pipeline" : {
          "type" : "string",
          "description" : "Path to the KSML pipeline definition YAML",
          "examples" : [ "pipelines/my-pipeline.yaml" ]
        },
        "schemaDirectory" : {
          "type" : "string",
          "description" : "Path to Avro schema files directory",
          "examples" : [ "schemas" ]
        },
        "registry" : {
          "type" : "array",
          "items" : {
            "type" : "object",
            "description" : "A registry entry mapping a topic to its key and value types for mock schema registry population",
            "properties" : {
              "topic" : {
                "type" : "string",
                "description" : "Kafka topic name",
                "examples" : [ "my-topic", "sensor-data" ]
              },
              "keyType" : {
                "type" : "string",
                "description" : "Key serialization type",
                "default" : "string",
                "examples" : [ "string", "avro:MyKeySchema" ]
              },
              "valueType" : {
                "type" : "string",
                "description" : "Value serialization type",
                "default" : "string",
                "examples" : [ "string", "avro:SensorData", "confluent_avro" ]
              }
            },
            "required" : [ "topic" ]
          },
          "description" : "Registry entries mapping topics to their key/value types for mock schema registry population"
        },
        "produce" : {
          "type" : "array",
          "items" : {
            "type" : "object",
            "description" : "A block that defines test data to be produced to a topic",
            "properties" : {
              "topic" : {
                "type" : "string",
                "description" : "Target Kafka topic name",
                "examples" : [ "input-topic", "sensor-data" ]
              },
              "keyType" : {
                "type" : "string",
                "description" : "Key serialization type",
                "default" : "string",
                "examples" : [ "string", "avro:MyKeySchema", "json", "binary" ]
              },
              "valueType" : {
                "type" : "string",
                "description" : "Value serialization type",
                "default" : "string",
                "examples" : [ "string", "avro:SensorData", "json", "binary" ]
              },
              "messages" : {
                "type" : "array",
                "items" : {
                  "type" : "object",
                  "description" : "A single test message with key, value, and optional timestamp",
                  "properties" : {
                    "key" : {
                      "description" : "Message key",
                      "examples" : [ "sensor-1", "user-42" ]
                    },
                    "value" : {
                      "description" : "Message value (string or structured data)"
                    },
                    "timestamp" : {
                      "type" : "integer",
                      "description" : "Optional timestamp in epoch milliseconds",
                      "examples" : [ "1709200000000" ]
                    }
                  },
                  "required" : [ "key", "value" ]
                },
                "description" : "Inline test messages to produce"
              },
              "generator" : {
                "type" : "object",
                "description" : "Generator function definition (KSML generator syntax)"
              },
              "count" : {
                "type" : "integer",
                "description" : "Number of times to invoke the generator function"
              }
            },
            "required" : [ "topic" ]
          },
          "description" : "List of produce blocks defining test data to send to input topics"
        },
        "assert" : {
          "type" : "array",
          "items" : {
            "type" : "object",
            "description" : "A block that defines assertions to run against pipeline output",
            "properties" : {
              "topic" : {
                "type" : "string",
                "description" : "Output topic to read records from",
                "examples" : [ "output-topic" ]
              },
              "stores" : {
                "type" : "array",
                "items" : {
                  "type" : "string"
                },
                "description" : "State store names to inject into the Python assertion context",
                "examples" : [ "my_store" ]
              },
              "code" : {
                "type" : "string",
                "description" : "Python assertion code to execute"
              }
            },
            "required" : [ "code" ]
          },
          "description" : "List of assertion blocks defining expected outcomes"
        }
      },
      "required" : [ "name", "pipeline", "produce", "assert" ]
    }
  },
  "required" : [ "test" ]
}